# ── Telegram Bot (required for bot mode) ──────────────────
BOT_TOKEN=your_bot_token
OWNER_ID=your_telegram_id

# ── Telegram Userbot (required for userbot mode) ───────────
# Get from https://my.telegram.org → API development tools
API_ID=your_api_id
API_HASH=your_api_hash

# ── Shared ─────────────────────────────────────────────────
REMOVE_TAG=True
